# UMBRA ONLINE - Environment Configuration
# Copy this file to .env and update values for your environment

# Server Configuration
NODE_ENV=production
PORT=3000

# Domain (used for CORS)
DOMAIN=labzts.fun

# WebSocket path
WS_PATH=/ws

# Admin Map Editor — REQUIRED if you enable the map editor
# Generate a strong random password, e.g.: node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
ADMIN_MAP_PASSWORD=CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD

# Set to 'false' to disable the in-game map editor (recommended for production)
ENABLE_MAP_EDITOR=false

# Allowed origins for WebSocket connections (comma-separated, leave empty to allow all in dev)
# ALLOWED_ORIGINS=https://yourdomain.com,http://yourdomain.com

# Rate limiting
# MAX_CONNECTIONS_PER_IP=5
# RATE_LIMIT_MESSAGES=10
# RATE_LIMIT_WINDOW_MS=1000
